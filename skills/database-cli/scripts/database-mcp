#!/usr/bin/env python3
import json
import re
import subprocess
import sys
from pathlib import Path


SKILL_ROOT = Path(__file__).resolve().parents[1]
DB_QUERY = SKILL_ROOT / "scripts" / "db-query"
SERVER_VERSION = "0.4.0"


def config_paths(explicit_path=None):
    if explicit_path:
        return [Path(explicit_path).expanduser()]
    return [
        SKILL_ROOT / "connections.local.json",
        Path.cwd() / "connections.local.json",
        Path.home() / ".config" / "database-cli" / "connections.json",
    ]


def load_config(explicit_path=None, required=False):
    for path in config_paths(explicit_path):
        if path.exists():
            with path.open("r", encoding="utf-8") as handle:
                return json.load(handle), path
    if required:
        paths = ", ".join(str(path) for path in config_paths(explicit_path))
        raise ValueError(f"No config file found. Checked: {paths}")
    return {}, None


def tool_schema(config_path=None):
    common_config = {
        "type": "string",
        "description": "Optional path to database-cli connections JSON.",
    }
    env = {"type": "string", "description": "Configured database-cli environment name."}
    base_tools = [
        {
            "name": "list_envs",
            "description": "List configured database-cli environments.",
            "inputSchema": {
                "type": "object",
                "properties": {"config": common_config},
                "additionalProperties": False,
            },
        },
        {
            "name": "query_readonly",
            "description": "Run a safe read-only SQL statement through database-cli.",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "config": common_config,
                    "env": env,
                    "sql": {"type": "string", "description": "Read-only SQL statement."},
                    "schema": {"type": "string", "description": "Optional schema/catalog override."},
                    "format": {"type": "string", "enum": ["json", "csv", "markdown", "text", "yaml"]},
                    "limit": {"type": "integer", "minimum": 0},
                    "no_auto_limit": {"type": "boolean"},
                },
                "required": ["env", "sql"],
                "additionalProperties": False,
            },
        },
        {
            "name": "inspect",
            "description": "Inspect a database source or one table through database-cli.",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "config": common_config,
                    "env": env,
                    "target": {"type": "string", "description": "Optional table/source target."},
                    "schema": {"type": "string", "description": "Optional schema/catalog override."},
                    "format": {"type": "string", "enum": ["json", "csv", "markdown", "text", "yaml"]},
                },
                "required": ["env"],
                "additionalProperties": False,
            },
        },
        {
            "name": "search_objects",
            "description": "Search schema/table/column/index/procedure metadata with a SQL LIKE pattern.",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "config": common_config,
                    "env": env,
                    "pattern": {"type": "string", "description": "SQL LIKE pattern, e.g. %order_no%."},
                    "object_type": {"type": "string", "enum": ["schema", "table", "column", "index", "procedure", "function"]},
                    "detail_level": {"type": "string", "enum": ["names", "summary", "full"]},
                    "schema": {"type": "string", "description": "Optional schema/database filter."},
                    "table": {"type": "string", "description": "Optional table filter for column/index search."},
                    "format": {"type": "string", "enum": ["json", "csv", "markdown", "text", "yaml"]},
                    "limit": {"type": "integer", "minimum": 0},
                },
                "required": ["env", "pattern"],
                "additionalProperties": False,
            },
        },
        {
            "name": "check_sql",
            "description": "Validate database-cli read-only SQL safety without executing it.",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "sql": {"type": "string", "description": "SQL statement to validate."},
                    "limit": {"type": "integer", "minimum": 0},
                    "no_auto_limit": {"type": "boolean"},
                },
                "required": ["sql"],
                "additionalProperties": False,
            },
        },
    ]
    config, _ = load_config(config_path, required=False)
    tools = config.get("tools", {})
    if isinstance(tools, dict):
        for name, spec in sorted(tools.items()):
            if not is_valid_tool_name(name) or not isinstance(spec, dict):
                continue
            parameters = spec.get("parameters", {})
            properties = {"config": common_config}
            required = []
            if isinstance(parameters, dict):
                for param_name, param_spec in parameters.items():
                    if not is_valid_param_name(param_name):
                        continue
                    schema = parameter_schema(param_spec)
                    properties[param_name] = schema
                    if isinstance(param_spec, dict) and "default" not in param_spec and not param_spec.get("optional"):
                        required.append(param_name)
            properties["_format"] = {"type": "string", "enum": ["json", "csv", "markdown", "text", "yaml"]}
            properties["_limit"] = {"type": "integer", "minimum": 0}
            properties["_print_command"] = {"type": "boolean"}
            base_tools.append(
                {
                    "name": name,
                    "description": spec.get("description") or f"Run configured database-cli tool '{name}'.",
                    "inputSchema": {
                        "type": "object",
                        "properties": properties,
                        "required": required,
                        "additionalProperties": False,
                    },
                }
            )
    return base_tools


def is_valid_tool_name(name):
    return bool(re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]{0,63}", str(name)))


def is_valid_param_name(name):
    return bool(re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*", str(name)))


def parameter_schema(param_spec):
    if not isinstance(param_spec, dict):
        return {"type": "string"}
    schema = {"type": param_spec.get("type", "string")}
    if param_spec.get("description"):
        schema["description"] = param_spec["description"]
    if "enum" in param_spec:
        schema["enum"] = param_spec["enum"]
    if "minimum" in param_spec:
        schema["minimum"] = param_spec["minimum"]
    if "maximum" in param_spec:
        schema["maximum"] = param_spec["maximum"]
    return schema


def add_common_args(cmd, args):
    if args.get("config"):
        cmd.extend(["--config", args["config"]])
    if args.get("format"):
        cmd.extend(["--format", args["format"]])
    if args.get("limit") is not None:
        cmd.extend(["--limit", str(args["limit"])])
    if args.get("schema"):
        cmd.extend(["--schema", args["schema"]])
    if args.get("no_auto_limit"):
        cmd.append("--no-auto-limit")


def command_for_tool(name, args):
    cmd = [str(DB_QUERY)]
    if name == "list_envs":
        if args.get("config"):
            cmd.extend(["--config", args["config"]])
        cmd.append("--list-envs")
        return cmd
    if name == "query_readonly":
        add_common_args(cmd, args)
        cmd.extend(["--env", args["env"], "--sql", args["sql"]])
        return cmd
    if name == "inspect":
        add_common_args(cmd, args)
        cmd.extend(["--env", args["env"], "--inspect"])
        if args.get("target"):
            cmd.append(args["target"])
        return cmd
    if name == "search_objects":
        add_common_args(cmd, args)
        cmd.extend(["--env", args["env"], "--search-objects", args["pattern"]])
        if args.get("object_type"):
            cmd.extend(["--object-type", args["object_type"]])
        if args.get("detail_level"):
            cmd.extend(["--detail-level", args["detail_level"]])
        if args.get("table"):
            cmd.extend(["--table", args["table"]])
        return cmd
    if name == "check_sql":
        if args.get("limit") is not None:
            cmd.extend(["--limit", str(args["limit"])])
        if args.get("no_auto_limit"):
            cmd.append("--no-auto-limit")
        cmd.extend(["--check-sql", args["sql"]])
        return cmd
    raise ValueError(f"Unknown tool '{name}'.")


def sql_literal(value):
    if value is None:
        return "NULL"
    if isinstance(value, bool):
        return "TRUE" if value else "FALSE"
    if isinstance(value, (int, float)) and not isinstance(value, bool):
        return str(value)
    return "'" + str(value).replace("'", "''") + "'"


def validate_custom_arg(name, spec, value):
    if not isinstance(spec, dict):
        return value
    if value is None:
        return value
    if "enum" in spec and value not in spec["enum"]:
        allowed = ", ".join(str(item) for item in spec["enum"])
        raise ValueError(f"Parameter '{name}' must be one of: {allowed}.")
    expected = spec.get("type", "string")
    if expected == "integer":
        if isinstance(value, bool):
            raise ValueError(f"Parameter '{name}' must be an integer.")
        converted = int(value)
    elif expected == "number":
        if isinstance(value, bool):
            raise ValueError(f"Parameter '{name}' must be a number.")
        converted = float(value)
    elif expected == "boolean":
        if isinstance(value, bool):
            return value
        if str(value).lower() in {"true", "1", "yes"}:
            return True
        if str(value).lower() in {"false", "0", "no"}:
            return False
        raise ValueError(f"Parameter '{name}' must be a boolean.")
    else:
        return str(value)
    if "minimum" in spec and converted < spec["minimum"]:
        raise ValueError(f"Parameter '{name}' must be >= {spec['minimum']}.")
    if "maximum" in spec and converted > spec["maximum"]:
        raise ValueError(f"Parameter '{name}' must be <= {spec['maximum']}.")
    return converted


def render_custom_sql(spec, args):
    sql = spec.get("sql")
    if not sql:
        raise ValueError("Configured tool is missing sql.")
    parameters = spec.get("parameters", {})
    values = {}
    if isinstance(parameters, dict):
        for name, param_spec in parameters.items():
            if not is_valid_param_name(name):
                continue
            if name in args:
                value = args[name]
            elif isinstance(param_spec, dict) and "default" in param_spec:
                value = param_spec["default"]
            elif isinstance(param_spec, dict) and param_spec.get("optional"):
                value = None
            else:
                raise ValueError(f"Missing required parameter '{name}'.")
            values[name] = validate_custom_arg(name, param_spec, value)

    def replace(match):
        name = match.group(1)
        if name not in values:
            raise ValueError(f"SQL references unknown parameter '{name}'.")
        return sql_literal(values[name])

    return re.sub(r"(?<!:):([A-Za-z_][A-Za-z0-9_]*)", replace, sql)


def command_for_custom_tool(name, args):
    config, _ = load_config(args.get("config"), required=True)
    tools = config.get("tools", {})
    if name not in tools or not isinstance(tools[name], dict):
        raise ValueError(f"Unknown tool '{name}'.")
    spec = tools[name]
    env = spec.get("env") or args.get("env")
    if not env:
        raise ValueError(f"Configured tool '{name}' must define env.")
    sql = render_custom_sql(spec, args)
    cmd = [str(DB_QUERY)]
    if args.get("config"):
        cmd.extend(["--config", args["config"]])
    if args.get("_format"):
        cmd.extend(["--format", args["_format"]])
    if args.get("_limit") is not None:
        cmd.extend(["--limit", str(args["_limit"])])
    if spec.get("schema"):
        cmd.extend(["--schema", spec["schema"]])
    if args.get("_print_command"):
        cmd.append("--print-command")
    cmd.extend(["--env", env, "--sql", sql])
    return cmd


def run_tool(name, args):
    try:
        cmd = command_for_tool(name, args)
    except ValueError:
        cmd = command_for_custom_tool(name, args)
    proc = subprocess.run(cmd, text=True, capture_output=True, check=False)
    text = proc.stdout
    if proc.stderr:
        text = text + ("\n" if text else "") + proc.stderr
    structured = {
        "exit_code": proc.returncode,
        "stdout": proc.stdout.strip(),
        "stderr": proc.stderr.strip(),
    }
    if proc.stdout.strip():
        try:
            structured["json"] = json.loads(proc.stdout)
        except json.JSONDecodeError:
            pass
    return {
        "content": [{"type": "text", "text": text.strip()}],
        "structuredContent": structured,
        "isError": proc.returncode != 0,
    }


def error_response(message, code=-32603):
    return {"jsonrpc": "2.0", "error": {"code": code, "message": message}}


def handle(message):
    method = message.get("method")
    response = {"jsonrpc": "2.0"}
    if "id" in message:
        response["id"] = message["id"]

    try:
        if method == "initialize":
            response["result"] = {
                "protocolVersion": "2024-11-05",
                "capabilities": {"tools": {}},
                "serverInfo": {"name": "database-cli", "version": SERVER_VERSION},
            }
        elif method == "tools/list":
            params = message.get("params") or {}
            arguments = params.get("arguments") or {}
            response["result"] = {"tools": tool_schema(arguments.get("config"))}
        elif method == "tools/call":
            params = message.get("params") or {}
            response["result"] = run_tool(params["name"], params.get("arguments") or {})
        elif method and method.startswith("notifications/"):
            return None
        else:
            response["error"] = {"code": -32601, "message": f"Unknown method '{method}'."}
    except KeyError as exc:
        response["error"] = {"code": -32602, "message": f"Missing required field: {exc}"}
    except (OSError, ValueError, subprocess.SubprocessError) as exc:
        response["error"] = {"code": -32603, "message": str(exc)}
    return response


def parse_content_length_frames(data):
    messages = []
    offset = 0
    while offset < len(data):
        header_end = data.find(b"\r\n\r\n", offset)
        if header_end == -1:
            break
        headers = data[offset:header_end].decode("ascii", errors="replace").split("\r\n")
        length = None
        for header in headers:
            name, _, value = header.partition(":")
            if name.lower() == "content-length":
                length = int(value.strip())
        if length is None:
            break
        start = header_end + 4
        end = start + length
        messages.append(json.loads(data[start:end].decode("utf-8")))
        offset = end
    return messages


def read_messages(data):
    if data.lstrip().startswith(b"Content-Length:"):
        return parse_content_length_frames(data), True
    messages = [json.loads(line) for line in data.decode("utf-8").splitlines() if line.strip()]
    return messages, False


def write_response(response, framed):
    raw = json.dumps(response, separators=(",", ":"), ensure_ascii=False).encode("utf-8")
    if framed:
        sys.stdout.buffer.write(f"Content-Length: {len(raw)}\r\n\r\n".encode("ascii"))
        sys.stdout.buffer.write(raw)
    else:
        sys.stdout.write(raw.decode("utf-8") + "\n")
    sys.stdout.flush()


def main():
    data = sys.stdin.buffer.read()
    if not data:
        return 0
    try:
        messages, framed = read_messages(data)
    except (ValueError, json.JSONDecodeError) as exc:
        write_response(error_response(f"Invalid JSON-RPC input: {exc}", -32700), False)
        return 0
    for message in messages:
        response = handle(message)
        if response is not None and "id" in response:
            write_response(response, framed)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
